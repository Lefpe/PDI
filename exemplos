def threshold_binario(imagem, valor=127):
    gray = cv2.cvtColor(imagem, cv2.COLOR_BGR2GRAY)
    _, th = cv2.threshold(gray, valor, 255, cv2.THRESH_BINARY)
    return th

def threshold_binario_inv(imagem, valor=127):
    gray = cv2.cvtColor(imagem, cv2.COLOR_BGR2GRAY)
    _, th = cv2.threshold(gray, valor, 255, cv2.THRESH_BINARY_INV)
    return th

def threshold_truncado(imagem, valor=127):
    gray = cv2.cvtColor(imagem, cv2.COLOR_BGR2GRAY)
